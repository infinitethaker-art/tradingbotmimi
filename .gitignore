# ── Secrets & credentials ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
credentials.json
token.json

# ── Runtime state ─────────────────────────────────────────────────────────────
db/
.tmp/
pending_intent.json
*.lock

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Research (raw data and large exports ignored; safe artifacts tracked) ──────
# Use research/* (not research/) so git still descends into subdirs for exceptions.
research/*
!research/backtest/
research/backtest/*
!research/backtest/*.py
!research/backtest/*_results.json
!research/notebooks/
research/notebooks/*
!research/notebooks/*.md

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
